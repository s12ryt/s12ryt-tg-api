# Web Console Authentication Mode (optional)
#   telegram (default) — users login via Telegram Bot /web OTP link.
#                        BOT_TOKEN and ADMIN_ID are required.
#   password            — standalone web-only mode, Bot is NOT started.
#                        First visit shows a setup page to create the admin account.
#                        BOT_TOKEN and ADMIN_ID are NOT required.
# WEB_AUTH_MODE=telegram

# Custom web login path (optional, anti-scraping)
# When set (e.g. /my-secret-login), the default /web/ entry returns 404 and the
# web panel is only accessible at this custom path. Must start with /.
# Default: /web/login (meaning the custom path is disabled and /web/ works normally)
# LOGIN_WEB_PATH=

BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_user_id
API_PORT=8000
DATABASE_PATH=./data/bot.db
DEFAULT_API_URL=http://localhost:8000

# Cloud database (optional) — leave empty to use local SQLite (DATABASE_PATH).
#
# When set, the service connects to a cloud database instead of the local
# SQLite file. The scheme determines the driver:
#   postgres://  or postgresql://  → PostgreSQL
#   mysql://     or mariadb://     → MySQL 
#
# Examples:
#   DATABASE_URL=postgres://user:password@host:5432/dbname
#   DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
#   DATABASE_URL=mysql://user:password@host:3306/dbname
#   DATABASE_URL=mariadb://user:password@host:3306/dbname
#
# The `pg` / `mysql2` npm packages are optional dependencies — they are
# dynamically imported only when needed, so SQLite-only deployments do not
# require them to be installed.
# DATABASE_URL=

# Node.js plugins (advanced/manual fallback)
# Preferred install path: Web Console -> 插件管理 -> upload .js/.mjs or GitHub URL.
# This env var is kept for manual boot-time loading. Relative paths are resolved
# from the nodejs/ working directory. Leave empty to rely on Web-installed plugins.
# Paths must point to an existing .js/.mjs file, or to a directory containing
# plugin.json main, package.json module/main, index.mjs, or index.js.
# Example: NODEJS_PLUGIN_PATHS=../plugin-example/dist/index.js
NODEJS_PLUGIN_PATHS=

# Node.js memory limit (optional, MB; supports one decimal place)
# Controls V8 heap limit for npm scripts, start.js, and the built-in updater.
# Example: memory=256.5
# memory=

# Cloudflare Tunnel (optional)
# Leave empty to disable.
# CLOUDFLARE_TUNNEL=quick    → temporary https://xxx.trycloudflare.com URL (no account needed)
# CLOUDFLARE_TUNNEL=token    → named tunnel with your own domain (requires CLOUDFLARE_TOKEN)
CLOUDFLARE_TUNNEL=
CLOUDFLARE_TOKEN=

# Update System — Network (optional)
# These settings help the built-in updater reach GitHub in restricted networks.
#
# GITHUB_MIRROR: prefix-mode mirror for GitHub API + tarball downloads.
#   Example: GITHUB_MIRROR=https://ghproxy.com
#   Result:  https://api.github.com/... → https://ghproxy.com/https://api.github.com/...
# GITHUB_MIRROR=
#
# NPM registry mirror for npm install during updates.
# China users: NPM_REGISTRY=https://registry.npmmirror.com
# NPM_REGISTRY=
#
# Standard proxy env vars are also auto-detected by the updater:
#   HTTPS_PROXY=http://127.0.0.1:7890
#   HTTP_PROXY=http://127.0.0.1:7890
#   ALL_PROXY=socks5://127.0.0.1:1080
